{% extends 'base.html.twig' %}

{% block title %}Hello CartController!{% endblock %}

{% block body %}
 <div class="container"><br>
    <h1>Cart</h1>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total Price</th>
                <th>action</th>
            </tr>
        </thead>
        <tbody>
            {% for item in items %}
                <tr>
                    <td>{{ item.product.name }}</td>
                    <td>{{ item.product.price }} DT</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ item.product.price * item.quantity }} DT</td>
                    <td>
                        <a href="{{ path('app_cart_product_remove', {'id': item.product.id}) }}" class="btn btn-danger">Remove</a>
                    </td>
                </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Your cart is empty.</td>
                    </tr>
                {% endfor %}
        </tbody>
    </table>
    {% if total > 0 %}
        <br><br>
        <h2>Total: {{ total }} DT</h2>
    
    <div class="row">
        <a href="" class="btn btn-primary col-2 m-lg-1">Valider la commande</a>
        <a href="{{ path('app_cart_remove') }}" class="btn btn-outline-danger col-2 m-lg-1">supprimer le panier</a>
    </div>
    {% endif %}
 </div>
{% endblock %}
